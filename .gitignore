
# Specific virtualenv directories (redundant but explicit)
hsenv/Lib/
hsenv/Scripts/
hsenv/Include/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
.coverage
.cache
.pytest_cache/
nosetests.xml
coverage.xml
htmlcov/

# Jupyter Notebook checkpoints
.ipynb_checkpoints

# IDE/editor directories
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Logs and databases
*.log
*.sqlite3

# Environment variables / secrets
.env
.env.*

# OS generated files
.DS_Store
Thumbs.db

# PyInstaller
*.manifest
*.spec

# Pyre
.pyre/